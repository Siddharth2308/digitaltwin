  <!-- All 4 exported meshes share one native coordinate convention where the "up"/thin
       axis is local Y (bed's own thin dimension is Y, dy=0.111), not Z. RViz/ROS expect
       Z-up (the Grid is drawn flat in the Fixed Frame's own X-Y plane). Rather than bake
       a correction into every link's mesh, add one virtual "world" root above bed that
       carries the whole Y-up -> Z-up conversion, so bed/y2/x_axis/x_axis_gantry and all
       their already-tuned relative joints stay untouched. Rx(+90deg) maps native
       (x,y,z) -> (x,-z,y): native Y (up) lands on new Z (up, same sign preserved).
       Set RViz's Fixed Frame to "world" (not "bed") for this to take effect. -->
  <link name="world"/>
  <joint name="world_to_bed" type="fixed">
    <parent link="world"/>
    <child link="bed"/>
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
  </joint>

  <!-- bed is the static frame reference; y2 (Y-rail pair) is bolted rigidly under it.
       Bounding-box check: y2's span nests fully inside bed's span on the axis matched
       to bed's end-extrusions - identity origin is well-grounded here. -->
  <joint name="bed_to_y2" type="fixed">
    <parent link="bed"/>
    <child link="y2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- x_axis (the arc/gantry bridge) slides along y2's rails.
       y2 and bed both contain a _40x80x1509_v6 extrusion (1509mm) running along local X,
       that's the rail direction, confirmed by user: all 4 parts exported from the
       same position/orientation with no relative frame change.
       Iteration 2: user confirmed the first rotation attempt (roll=90 pitch=0 yaw=-90)
       used the right plane/axis but the wrong rotational direction, so this flips both
       the yaw and pitch signs (roll=90 pitch=0 yaw=+90). axis re-derived the same way as
       before so the prismatic motion still tracks y2's local X after the new rotation.
       Also added an xyz translation: rotating about y2's origin flung x_axis's actual
       geometry (its own bbox centroid sits well away from 0 0 0 in its local frame) far
       from the bed. This offset re-centers that centroid onto y2's own centroid as a
       first-pass "somewhere over the rails" placement, not an exact fit, check visually
       and adjust; the along-rail (local X) component in particular should really be set
       by wherever the real machine's home position is, not just centered.
       Iteration 3: user reported x_axis clipping through the bed. Since native local Y
       is the axis that becomes "up" (world Z) once world_to_bed's Rx(90) is applied,
       clearance is added on this joint's Y component (was -0.064, now +0.15 more
       positive, i.e. 0.086) to lift x_axis clear of the bed surface.
       Iteration 4: user confirmed orientation/clearance now look right in rviz, but the
       TF triad showed this joint sliding along blue (local Z) when it should be green
       (local Y) - corrected directly per that visual read rather than re-deriving, since
       the earlier axis math clearly had an error somewhere. -->
  <joint name="y2_to_x_axis" type="prismatic">
    <parent link="y2"/>
    <child link="x_axis"/>
    <origin xyz="-0.464 0.086 -0.439" rpy="1.5708 0 1.5708"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.47" upper="0.47" effort="100" velocity="0.5"/>
  </joint>

  <!-- x_axis_gantry (tool head) slides along x_axis's crossbeam.
       x_axis contains a 40x80x1490_v3_6 extrusion (1490mm) running along local Z,
       that's the crossbeam the tool head rides on.
       Iteration 4: original symmetric -0.6/0.6 guess assumed the captured export pose
       was roughly centered on the crossbeam; user confirmed it's actually at one END of
       travel (negative values went off the physical beam, positive was fine), so the
       range is 0 to 1.2 instead - matches the crossbeam-length-minus-carriage-footprint
       estimate (~1.245m) from the original bounding-box scan almost exactly. -->
  <joint name="x_axis_to_x_axis_gantry" type="prismatic">
    <parent link="x_axis"/>
    <child link="x_axis_gantry"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="1.2" effort="100" velocity="0.5"/>
  </joint>

</robot>
